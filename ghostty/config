# macos option should be treated as Alt
macos-option-as-alt=true

# aesthetics
theme = TokyoNight Storm
font-family = JetBrains Mono Nerd Font Mono
background-opacity = 0.85
background-blur=16
background=#000000

# typography
font-size=16
font-thicken=true
font-thicken-strength=1
adjust-cell-height=1

# map CMD+S to Ctrl+S (for saving files in nvim)
keybind = super+s=text:\x13

# TMUX settings (\x1b\x20 = ALT+Space)

# Pane navigation
# left (sends ctrl+h)
keybind = super+h=text:\x08
# down (sends ctrl+j)
keybind = super+j=text:\x0a
# up (sends ctrl+k)
keybind = super+k=text:\x0b
# right (sends ctrl+l)
keybind = super+l=text:\x0c

# close
keybind = unconsumed:super+w=text:\x1b\x20x
# zoom
keybind = unconsumed:super+z=text:\x1b\x20z

# select window
keybind = unconsumed:super+shift+w=text:\x1b\x20w
# prev session
keybind = unconsumed:super+shift+h=text:\x1b\x20(
# next session
keybind = unconsumed:super+shift+l=text:\x1b\x20)

# open lazygit in popup
keybind = unconsumed:super+g=text:\x1b\x20g

# switch to window
keybind = unconsumed:super+1=text:\x1b\x20\1
keybind = unconsumed:super+2=text:\x1b\x20\2
keybind = unconsumed:super+3=text:\x1b\x20\3
keybind = unconsumed:super+4=text:\x1b\x20\4
keybind = unconsumed:super+5=text:\x1b\x20\5
keybind = unconsumed:super+6=text:\x1b\x20\6
keybind = unconsumed:super+7=text:\x1b\x20\7
keybind = unconsumed:super+8=text:\x1b\x20\8
keybind = unconsumed:super+9=text:\x1b\x20\9
keybind = unconsumed:super+0=text:\x1b\x20\0

# switch tmux window prev / next
keybind = unconsumed:super+shift+p=text:\x1b\x20p
keybind = unconsumed:super+shift+n=text:\x1b\x20n

# CMD+SHIFT+s to open session switcher
keybind = unconsumed:super+shift+s=text:\x1b\x20s
# CMD+SHIFT+o to open session switcher
keybind = unconsumed:super+shift+o=text:\x1b\x20o

# CMD+t to open new tmux window (uses custom bind t to preserve current path)
keybind = unconsumed:super+t=text:\x1b\x20t

